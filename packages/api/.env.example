NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Supabase (get from your Supabase project settings)
DATABASE_URL=postgresql://postgres:password@localhost:5432/grocery
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Redis (for BullMQ job queue)
REDIS_URL=redis://localhost:6379

# Anthropic Claude API (for image recognition)
ANTHROPIC_API_KEY=sk-ant-your-key

# Kroger API (apply at https://developer.kroger.com)
KROGER_CLIENT_ID=
KROGER_CLIENT_SECRET=

# Walmart API
WALMART_API_KEY=

# Google Maps (optional, for route optimization)
GOOGLE_MAPS_API_KEY=

# Household config
HOUSEHOLD_ID=family-default
HOUSEHOLD_SIZE=2
